    "firstTitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to Warm Kitty" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "欢迎来到 Warm Kitty" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "歡迎來到 Warm Kitty" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Warm Kitty へようこそ" } }
      }
    },
    "firstBody" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "I gently warm your laptop to toast your hands. Pick a time, tap start, and I stop on my own when it runs out." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "我会让电脑轻轻发点热，帮你焐暖一双小手。选个时长就开始，时间一到自动停下。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "我會讓電腦輕輕發點熱，幫你焐暖一雙小手。選個時長就開始，時間一到自動停下。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "PCをほんのり発熱させて、手をぬくぬくにします。時間を選んで開始、0になったら自動で止まります。" } }
      }
    },
    "firstBtn" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Got it, let's go" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "好的，开始吧" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "好的，開始吧" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "はじめる" } }
      }
    },
    "narration.standby" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pick a time and I'll warm your hands~" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "选个时长，我来帮你焐暖小手～" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "選個時長，我來幫你焐暖小手～" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "時間を選んでね、手を暖めてあげる～" } }
      }
    },
    "narration.ending" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Phew~ all warm. Toasty hands?" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "呼～暖好啦，手是不是热乎乎的？" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "呼～暖好啦，手是不是熱乎乎的？" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ふぅ〜暖まったよ。ぽかぽかでしょ？" } }
      }
    },
    "narration.warming.0" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Purr purr… warming your hands up~" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "呼噜呼噜…正在帮你把手焐热～" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "呼嚕呼嚕…正在幫你把手焐熱～" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ゴロゴロ…手を暖めてるよ～" } }
      }
    },
    "narration.warming.1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Nice and cozy, just a little longer." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暖暖的，再坚持一下下就好啦。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "暖暖的，再堅持一下下就好啦。" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ぬくぬく、もう少しだけね。" } }
      }
    },
    "narration.warming.2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Like cupping a fresh mug of hot cocoa~" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "像捧着一杯刚泡好的热可可一样～" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "像捧著一杯剛泡好的熱可可一樣～" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "淹れたてのホットココアみたいに～" } }
      }
    },
    "narration.warming.3" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Toasty all over. Feeling better?" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "热乎乎的，是不是舒服多了？" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "熱乎乎的，是不是舒服多了？" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ぽかぽか。楽になったかな？" } }
      }
